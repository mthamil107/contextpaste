{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ContextPaste",
  "version": "0.2.0",
  "identifier": "com.contextpaste.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ContextPaste",
        "width": 720,
        "height": 560,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "center": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "ContextPaste"
    }
  },
  "bundle": {
    "resources": [
      "models/all-MiniLM-L6-v2.onnx",
      "models/tokenizer.json"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "AI-Powered Smart Clipboard Manager",
    "longDescription": "ContextPaste is a free, open-source clipboard manager that uses local AI to predict what you want to paste based on your workflow patterns.",
    "copyright": "Copyright 2026 Thamilvendhan. GPL-3.0 License.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
